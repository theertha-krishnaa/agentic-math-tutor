{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/ask", "dest": "/api/index.py" },
    { "src": "/health", "dest": "/api/index.py" },
    { "src": "/stats", "dest": "/api/index.py" },
    { "src": "/add-knowledge", "dest": "/api/index.py" },
    { "src": "/", "dest": "/index.html" }
  ]
}
