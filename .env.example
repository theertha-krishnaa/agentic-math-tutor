# ── LLM ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=api
GROQ_MODEL=llama3-70b-8192

# ── Qdrant Cloud (required for Vercel deployment) ─────────────────────────────

QDRANT_URL=api
QDRANT_API_KEY=api

# ── Qdrant Local (only for local dev without cloud) ───────────────────────────
# These are ignored when QDRANT_URL is set
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# ── App config ────────────────────────────────────────────────────────────────
COLLECTION_NAME=math_knowledge
CONFIDENCE_THRESHOLD=0.75

# ── Optional: Tavily search (only if you use TavilySearch in tools.py) ────────
# TAVILY_API_KEY=api

# Leave blank or set to * to allow all origins (fine for demo)
ALLOWED_ORIGINS=*
